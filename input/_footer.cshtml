<footer id="footer">
  <div class="inner">
    <section>
      @{
        IDocument rssFeed = Outputs["**/*.rss"].FirstOrDefault();
        IDocument atomFeed = Outputs["**/*.atom"].FirstOrDefault();
      }
      @if (rssFeed != null || atomFeed != null)
      {
        <h2>Feeds</h2>
        <ul class="actions small vertical">
          @if (rssFeed != null)
          {
            <li><a href="@Context.GetLink(rssFeed)" class="button small"><i class="fa fa-rss"></i> RSS Feed</a></li>
          }
          @if (atomFeed != null)
          {
            <li><a href="@Context.GetLink(atomFeed)" class="button small"><i class="fa fa-rss"></i> Atom Feed</a></li>
          }
        </ul>
      }
    </section>
    <section>
    </section>
    <ul class="copyright">
      @Html.Partial("_copyright")
      <li>Design: <a href="https://html5up.net">HTML5 UP</a></li>
      <li><a href="https://statiq.dev">Generated by Statiq</a></li>
    </ul>
  </div>
</footer>
